{
  "testRunner": "vitest",
  "mutate": [
    "src/domain/**/*.ts",
    "src/domain/**/*.tsx",
    "src/common/**/*.ts",
    "!src/**/*.test.{ts,tsx}",
    "!src/**/*.a11y.test.{ts,tsx}",
    "!src/**/index.ts"
  ],
  "reporters": ["html", "clear-text", "progress"],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "tempDirName": "stryker-tmp"
}
