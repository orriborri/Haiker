# =============================================================================
# Haiker Staging Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env files with real secrets.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://haiker:CHANGE_ME@postgres:5432/haiker

# Postgres container settings
POSTGRES_DB=haiker
POSTGRES_USER=haiker
# SECRET - use secret manager
POSTGRES_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Object Storage (MinIO / S3-compatible)
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=http://minio:9000
STORAGE_BUCKET=haiker-uploads
# SECRET - use secret manager
STORAGE_ACCESS_KEY_ID=minioadmin
# SECRET - use secret manager
STORAGE_SECRET_ACCESS_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Authentication (OIDC)
# -----------------------------------------------------------------------------
OIDC_ISSUER_URL=https://your-issuer.example.com
# SECRET - use secret manager
OIDC_CLIENT_ID=CHANGE_ME
# SECRET - use secret manager
OIDC_CLIENT_SECRET=CHANGE_ME

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
RUST_LOG=info
LOG_FORMAT=json
SERVICE_NAME=haiker

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
