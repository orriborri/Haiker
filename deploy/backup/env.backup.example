# =============================================================================
# PostgreSQL Backup Environment Variables
# Copy this file to .env.backup and fill in production values.
# =============================================================================

# --- Backup User Credentials ---
# These must be DIFFERENT from the application database credentials (POSTGRES_USER/POSTGRES_PASSWORD).
# The backup user is created with REPLICATION privilege only.
BACKUP_POSTGRES_USER=backup_user
BACKUP_POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Encryption ---
# GPG symmetric passphrase used to encrypt backup archives.
# Store this securely (e.g., in a secrets manager). Loss of this key means loss of backups.
BACKUP_ENCRYPTION_KEY=CHANGE_ME_TO_A_STRONG_PASSPHRASE

# --- Retention ---
# Number of days to retain encrypted backup files before automatic deletion.
BACKUP_RETENTION_DAYS=7

# --- Schedule ---
# Cron expression for when base backups are performed.
# Default: daily at 02:00 UTC
BACKUP_SCHEDULE=0 2 * * *

# --- Storage ---
# Path inside the container where backups are stored (mapped to the postgres_backups volume).
BACKUP_STORAGE_PATH=/backups

# --- Monitoring ---
# Optional webhook URL for backup failure/success alerts (Slack, PagerDuty, etc.).
BACKUP_ALERT_WEBHOOK_URL=

# --- RPO Thresholds (for verification script) ---
# Maximum acceptable age of the latest base backup (in hours).
BACKUP_RPO_BASE_HOURS=24
# Maximum acceptable age of the latest WAL segment (in minutes).
BACKUP_RPO_WAL_MINUTES=15
# Storage usage percentage at which to emit a warning.
BACKUP_STORAGE_WARN_PERCENT=80

# =============================================================================
# MinIO Object Storage Backup Environment Variables
# These credentials must be DIFFERENT from the application MinIO credentials
# (MINIO_ROOT_USER / MINIO_ROOT_PASSWORD).
# =============================================================================

# --- Backup MinIO Instance Credentials ---
# Root user for the backup MinIO instance. Must be different from application credentials.
BACKUP_MINIO_ROOT_USER=backup_minio_admin
BACKUP_MINIO_ROOT_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Endpoints ---
# Endpoint of the backup MinIO instance (the replication target).
BACKUP_MINIO_ENDPOINT=http://minio-backup:9000

# --- Source MinIO Access (used by backup scripts) ---
# mc alias names for source and backup MinIO instances.
MINIO_SOURCE_ALIAS=source
MINIO_BACKUP_ALIAS=backup

# Endpoint of the source (production) MinIO instance.
MINIO_SOURCE_ENDPOINT=http://minio:9000

# Access credentials for reading from the source MinIO (backup service account).
MINIO_SOURCE_ACCESS_KEY=backup-svc
MINIO_SOURCE_SECRET_KEY=CHANGE_ME_TO_BACKUP_SERVICE_SECRET

# --- Encryption ---
# Server-side encryption key for backup objects (minimum 32 characters).
MINIO_BACKUP_ENCRYPTION_KEY=CHANGE_ME_TO_A_32_CHAR_ENCRYPTION_KEY

# --- Schedule ---
# Cron expression for MinIO backup schedule.
# Default: daily at 03:00 UTC
MINIO_BACKUP_SCHEDULE=0 3 * * *

# Fallback interval in seconds when cron is not available (default: 6 hours).
MINIO_BACKUP_INTERVAL_SECONDS=21600

# --- Retention ---
# Number of days to retain old backup object versions before deletion.
MINIO_BACKUP_RETENTION_DAYS=30

# --- Buckets ---
# Comma-separated list of buckets to replicate.
MINIO_BACKUP_BUCKETS=haiker-artifacts,haiker-uploads

# --- Monitoring ---
# Maximum hours since last backup before alerting critical.
MINIO_BACKUP_MAX_AGE_HOURS=24
# Storage percent threshold for capacity warnings.
MINIO_BACKUP_STORAGE_WARN_PERCENT=80

# =============================================================================
# Monitoring & Alerting Configuration
# Used by scripts/backup-monitor.sh for unified health monitoring.
# =============================================================================

# --- Alert Webhook ---
# URL for sending alert notifications (supports Slack, Discord, or generic HTTP POST).
# Leave empty to disable webhook alerts.
ALERT_WEBHOOK_URL=

# --- Alert Channel ---
# Channel or routing key for alert delivery (e.g., #backup-alerts for Slack).
ALERT_CHANNEL=#backup-alerts

# --- Capacity Thresholds ---
# Percentage of storage used before emitting a warning alert.
CAPACITY_WARNING_PERCENT=80
# Percentage of storage used before emitting a critical alert.
CAPACITY_CRITICAL_PERCENT=90

# --- Monitor Schedule ---
# Cron expression for when the monitoring script runs.
# Default: every 5 minutes.
MONITOR_SCHEDULE=*/5 * * * *
