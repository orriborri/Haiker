{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBackupReadSource",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:GetBucketVersioning"
      ],
      "Resource": [
        "arn:aws:s3:::haiker-artifacts",
        "arn:aws:s3:::haiker-artifacts/*",
        "arn:aws:s3:::haiker-uploads",
        "arn:aws:s3:::haiker-uploads/*"
      ]
    },
    {
      "Sid": "AllowBackupWriteTarget",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::haiker-artifacts",
        "arn:aws:s3:::haiker-artifacts/*",
        "arn:aws:s3:::haiker-uploads",
        "arn:aws:s3:::haiker-uploads/*"
      ]
    }
  ]
}
